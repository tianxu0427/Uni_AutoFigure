# =============================================================================
# AutoFigure-Edit 环境配置
# 仅支持阿里云百炼 DashScope；修改后重新运行 python autofigure2.py 即可生效
# =============================================================================

# -----------------------------------------------------------------------------
# 必填：百炼 API 密钥
# 用于步骤一生图、步骤二物体定位（dashscope 后端）、步骤四/五 SVG 多模态生成
# 获取：https://help.aliyun.com/zh/model-studio/get-api-key
# -----------------------------------------------------------------------------
AUTOFIGURE_API_KEY=sk-xx

# -----------------------------------------------------------------------------
# 模型名称（未填写时使用代码内置默认值）
# -----------------------------------------------------------------------------

# 步骤一：根据 paper method 文本生成学术示意图（通义万相文生图）
# 示例：wanx2.6-t2i、wanx2.1-t2i-turbo
AUTOFIGURE_IMAGE_MODEL=wanx2.1-t2i-turbo

# 步骤四/五：根据原图 + 标记图生成/优化 SVG（多模态对话）
# 示例：qwen3.6-plus、qwen-plus
AUTOFIGURE_SVG_MODEL=qwen3.6-plus

# 步骤二：物体定位（仅当 AUTOFIGURE_SAM_BACKEND=dashscope 时使用 Qwen-VL 返回边界框）
# 建议视觉定位模型，如 qwen3-vl-plus；与 SVG 模型可相同也可不同
AUTOFIGURE_MULTIMODAL_MODEL=qwen3.6-plus

# -----------------------------------------------------------------------------
# 步骤二：图标区域检测（SAM）后端与提示词
# -----------------------------------------------------------------------------

# 分割后端，可选：
#   dashscope — 百炼 Qwen-VL 物体定位（推荐，无需本地 SAM3）
#   gitee     — 模力方舟 SAM3 图像分割/目标检测（需下方 GITEE_* 配置）
#   roboflow  — Roboflow SAM3 API（需 AUTOFIGURE_ROBOFLOW_API_KEY）
#   local     — 本地安装 SAM3（需 GPU 与 sam3 库）
AUTOFIGURE_SAM_BACKEND=dashscope

# 逗号分隔的检测类别词，每个词单独请求一轮，如 icon、person、robot
AUTOFIGURE_SAM_PROMPT=icon,robot,animal,person

# -----------------------------------------------------------------------------
# SAM 第三方后端密钥（仅在后端为 roboflow / gitee 时需要）
# dashscope 后端复用上面的 AUTOFIGURE_API_KEY，无需单独配置
# -----------------------------------------------------------------------------
# AUTOFIGURE_ROBOFLOW_API_KEY=

# gitee 后端（AUTOFIGURE_SAM_BACKEND=gitee 时必填）
# AUTOFIGURE_GITEE_API_KEY=your_gitee_ai_token
# GITEE_SAM3_API_MODE=segmentation
# GITEE_SAM3_SEGMENTATION_URL=https://ai.gitee.com/v1/images/segmentation
# GITEE_SAM3_OBJECT_DETECTION_URL=https://ai.gitee.com/v1/images/object-detection

# Roboflow 接口地址（一般无需修改）
ROBOFLOW_API_URL=https://serverless.roboflow.com/sam3/concept_segment
# 主地址不可用时依次尝试的备用 URL，逗号分隔，可留空
ROBOFLOW_API_FALLBACK_URLS=

# -----------------------------------------------------------------------------
# 步骤三：阿里云通用图像分割去背景
# 开通视觉智能开放平台通用分割能力后，使用 RAM 用户 AccessKey
# -----------------------------------------------------------------------------
ALIBABA_CLOUD_ACCESS_KEY_ID=your_access_key_id
ALIBABA_CLOUD_ACCESS_KEY_SECRET=your_access_key_secret
# 可选：网络较慢或 OSS 连接偶发超时时调大
ALIYUN_IMAGESEG_CONNECT_TIMEOUT_MS=30000
ALIYUN_IMAGESEG_READ_TIMEOUT_MS=120000
ALIYUN_IMAGESEG_MAX_ATTEMPTS=5
