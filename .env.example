# AUTOFIGURE_SVG_FIX_PROVIDER=dashscope
# AUTOFIGURE_SVG_FIX_API_KEY=sk-xx
# AUTOFIGURE_SVG_FIX_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# AUTOFIGURE_SVG_FIX_MODEL=qwen-plus

# --- 切换 OpenAI 中转：注释上面 4 行，取消下面 4 行注释 ---
AUTOFIGURE_SVG_FIX_PROVIDER=openai
AUTOFIGURE_SVG_FIX_API_KEY=sk-xx
AUTOFIGURE_SVG_FIX_BASE_URL=https://api.openai-proxy.org/v1
AUTOFIGURE_SVG_FIX_MODEL=gpt-5.5

# =============================================================================
