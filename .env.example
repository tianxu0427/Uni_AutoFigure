# =============================================================================
# AutoFigure 环境配置
# 每个模块仅使用各自的 PROVIDER / API_KEY / BASE_URL / MODEL，互不复用
# =============================================================================

# =============================================================================
# 模块 1：文生图（步骤一）— 当前：OpenAI 中转
# =============================================================================
AUTOFIGURE_IMAGE_PROVIDER=openai
AUTOFIGURE_IMAGE_API_KEY=sk-xx
AUTOFIGURE_IMAGE_BASE_URL=https://api.openai-proxy.org/v1
AUTOFIGURE_IMAGE_MODEL=gpt-image-2-2026-04-21

# --- 切换 DashScope 万相：注释上面 4 行，取消下面 4 行注释 ---
# AUTOFIGURE_IMAGE_PROVIDER=dashscope
# AUTOFIGURE_IMAGE_API_KEY=sk-xx
# AUTOFIGURE_IMAGE_BASE_URL=https://dashscope.aliyuncs.com/api/v1/services/aigc/multimodal-generation/generation
# AUTOFIGURE_IMAGE_MODEL=wan2.6-t2i

# =============================================================================
# 模块 2：多模态（步骤四/五 SVG）— 当前：OpenAI 中转
# =============================================================================
AUTOFIGURE_MULTIMODAL_PROVIDER=openai
AUTOFIGURE_MULTIMODAL_API_KEY=sk-xx
AUTOFIGURE_MULTIMODAL_BASE_URL=https://api.openai-proxy.org/v1
AUTOFIGURE_MULTIMODAL_MODEL=gemini-3.1-pro-preview

# --- 切换 DashScope：注释上面 4 行，取消下面 4 行注释 ---
# AUTOFIGURE_MULTIMODAL_PROVIDER=dashscope
# AUTOFIGURE_MULTIMODAL_API_KEY=sk-xx
# AUTOFIGURE_MULTIMODAL_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# AUTOFIGURE_MULTIMODAL_MODEL=qwen3.6-plus

# =============================================================================
# 模块 3：SVG 语法修复（步骤 4.5 / 4.6）— 当前：DashScope
